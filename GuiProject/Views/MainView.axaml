<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:GuiProject.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="GuiProject.Views.MainView"
             x:DataType="vm:MainViewModel">
	<!--<<<<<<< Updated upstream


=======
>>>>>>> Stashed changes

	 ========================= -->
	<!-- BASE BUTTON -->
	<!-- ========================= -->
	<UserControl.Styles>
		<Style Selector="Button">
			<Setter Property="CornerRadius" Value="4"/>
			<Setter Property="FontWeight" Value="SemiBold"/>
			<Setter Property="HorizontalContentAlignment" Value="Center"/>
			<Setter Property="VerticalContentAlignment" Value="Center"/>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.15"/>
				</Transitions>
			</Setter>
		</Style>
	</UserControl.Styles>

	
	<Grid ColumnDefinitions="200,5,*,5,250">

		<!-- LEFT PANEL (Navigation) -->
		<Border Grid.Column="0" Background="#054680" Padding="10">
			<StackPanel Spacing="10">
				<TextBlock Text="Menu" FontSize="18" Foreground="White"/>
				<Button Content="Dashboard"/>
				<Button Content="Map"/>
				<Button Content="Settings"/>
			</StackPanel>
		</Border>

		<!-- SPLITTER 1 -->
		<GridSplitter Grid.Column="1"
                      Width="5"
                      Background="Gray"
                      ResizeDirection="Columns"/>

		<!-- CENTER PANEL (Flexible Content Area) -->
        <Border Grid.Column="2" Background="#2d2d2d">
			<StackPanel>
		
				<!-- Blue buttons -->
				<Button Classes="L fill blue" Content="Primary"/>
				<Button Classes="M outlined blue" Content="Info"/>
				<Button Classes="S ghost blue" Content="Link"/>

				<Button Content="Hover Me" Classes="L fill blue"/>

				<!-- Green buttons -->
				<Button Classes="L fill green" Content="Confirm"/>
				<Button Classes="M outlined green" Content="Success"/>
				<Button Classes="S ghost green" Content="Action"/>
				
				
			</StackPanel>
		</Border>

		<!-- SPLITTER 2 -->
		<GridSplitter Grid.Column="3"
                      Width="5"
                      Background="Gray"
                      ResizeDirection="Columns"/>

		<!-- RIGHT PANEL (Telemetry) -->
		<Border Grid.Column="4" Background="#054680" Padding="10">
			<StackPanel Spacing="10">
				<TextBlock Text="Telemetry" FontSize="18" Foreground="White"/>

				<TextBlock Text="Status:" Foreground="White"/>
				<TextBlock Text="{Binding Status}" Foreground="LightGreen"/>

				<TextBlock Text="Data:" Foreground="White"/>
				<TextBlock Text="{Binding TelemetryData}"
                           TextWrapping="Wrap"
                           Foreground="White"/>
			</StackPanel>
		</Border>

	</Grid>

</UserControl>