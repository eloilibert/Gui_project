<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:GuiProject.ViewModels"
			 xmlns:helpers="using:GuiProject.Helpers"
			 mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
			 x:Class="GuiProject.Views.MainView"
			 x:DataType="vm:MainViewModel">




	<Grid ColumnDefinitions="200,5,*,5,250">

		<!-- LEFT PANEL (Sidebar) -->
		<helpers:Sidebar Grid.Column="0"/>

		<!-- SPLITTER 1 -->
		<GridSplitter Grid.Column="1"
                      Width="5"
                      Background="Gray"
                      ResizeDirection="Columns"/>

		<!-- CENTER PANEL (Flexible Content Area) -->
		<Border Grid.Column="2" Background="#2d2d2d">
			<ContentControl Content="{Binding}">
				<!-- Future: switch between Map / Video / HUD -->
			</ContentControl>
		</Border>

		<!-- SPLITTER 2 -->
		<GridSplitter Grid.Column="3"
                      Width="5"
                      Background="Gray"
                      ResizeDirection="Columns"/>

		<!-- RIGHT PANEL (Telemetry) -->
		<Border Grid.Column="4" Background="#054680" Padding="10">
			<StackPanel Spacing="10">
				<TextBlock Text="Telemetry" FontSize="18" Foreground="White"/>

				<TextBlock Text="Status:" Foreground="White"/>
				<TextBlock Text="{Binding Status}" Foreground="LightGreen"/>

				<TextBlock Text="Data:" Foreground="White"/>
				<TextBlock Text="{Binding TelemetryData}"
                           TextWrapping="Wrap"
                           Foreground="White"/>
			</StackPanel>
		</Border>

	</Grid>

</UserControl>